---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = 'Casa Grande · Suministros y Servicios Industriales', current } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Suministros industriales y servicios de mantenimiento eléctrico, refrigeración y obra civil en Guayana. Contratista del estado desde 2001."
    />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logos/logo-blanco.png" />
    <link rel="apple-touch-icon" href="/images/logos/logo-blanco.png" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Casa Grande',
      url: Astro.site?.href ?? Astro.url.origin,
      logo: new URL('/images/logos/logo-with-no-bg.png', Astro.site ?? Astro.url.origin).href,
    })} />
  </head>
  <body>
    <Header current={current} />
    <slot />
    <Footer />

    <script>
      // Navegación para elementos con data-go (pilares, tarjetas, botones internos)
      const routes: Record<string, string> = {
        home: '/',
        nosotros: '/nosotros',
        suministros: '/suministros',
        servicios: '/servicios',
        experiencia: '/experiencia',
        contacto: '/contacto',
      };
      document.querySelectorAll<HTMLElement>('[data-go], [data-href]').forEach((el) => {
        el.style.cursor = 'pointer';
        el.addEventListener('click', (e) => {
          e.preventDefault();
          // Ruta literal (slugs dinámicos) tiene prioridad
          if (el.dataset.href) {
            window.location.href = el.dataset.href;
            return;
          }
          const go = el.dataset.go;
          if (!go) return;
          let url = routes[go] || '/';
          // Precarga del formulario de contacto según el botón de origen
          if (go === 'contacto' && (el.dataset.tipo || el.dataset.ref)) {
            const q = new URLSearchParams();
            if (el.dataset.tipo) q.set('tipo', el.dataset.tipo);
            if (el.dataset.ref) q.set('ref', el.dataset.ref);
            url += '?' + q.toString();
          }
          window.location.href = url;
        });
      });

      // Botones de WhatsApp (FAB, CTA del header ya es <a>, y botones .btn.wa)
      const WA = 'https://wa.me/584148984156';
      const waUrl = (msg?: string) =>
        msg ? `${WA}?text=${encodeURIComponent(msg)}` : WA;
      document.querySelectorAll<HTMLElement>('.btn.wa, a.fab, [data-wa-msg]').forEach((el) => {
        const target = waUrl(el.dataset.waMsg);
        if (el.tagName === 'A') {
          (el as HTMLAnchorElement).href = target;
          return;
        }
        el.style.cursor = 'pointer';
        el.addEventListener('click', () => window.open(target, '_blank'));
      });

      // Toggle visual de chips de filtro
      document
        .querySelectorAll('.filter-bar .chips, .table-head .chips')
        .forEach((group) => {
          group.addEventListener('click', (e) => {
            const t = e.target as HTMLElement;
            if (t.classList.contains('chip')) {
              group.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
              t.classList.add('active');
            }
          });
        });

      // Toggle visual de radios
      const radioGroup = document.getElementById('radioGroup');
      if (radioGroup) {
        radioGroup.addEventListener('change', () => {
          radioGroup.querySelectorAll('label').forEach((l) => {
            const input = l.querySelector('input') as HTMLInputElement | null;
            l.classList.toggle('checked', !!input?.checked);
          });
        });
      }
    </script>
  </body>
</html>
