---
import Layout from "../layouts/Layout.astro";
---

<Layout current="contacto" title="Contacto · Casa Grande">
<section class="view" id="view-contacto">
  <div class="page-hero">
    <div class="wrap">
      <div class="breadcrumb">Inicio <span class="sep">›</span> <span class="here">Contacto</span></div>
      <span class="eyebrow">Hablemos</span>
      <h1>Cotizaciones el mismo día.<br>Atención personalizada para su empresa.</h1>
      <p class="lede">WhatsApp es nuestro canal principal — respondemos en horas, no en días. También atendemos por llamada local y correo formal para órdenes de compra.</p>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="channels">
        <div class="channel featured">
          <div class="channel-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          </div>
          <span class="label" style="color:#a8a294;">canal principal</span>
          <h4>WhatsApp Business</h4>
          <div class="num-big">+58 414 8984156</div>
          <p class="desc">Cotizaciones, disponibilidad, seguimiento de pedidos y consultas técnicas. Respuesta en menos de 24 horas hábiles.</p>
          <button class="btn wa">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
            Abrir chat
          </button>
        </div>
        <div class="channel">
          <div class="channel-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <span class="label">llamada local</span>
          <h4>Teléfono fijo</h4>
          <div class="num-big">+58 286 9517336</div>
          <p class="desc">Para entes públicos y clientes que prefieren llamada. Lun-Vie · 8:00 AM – 5:00 PM.</p>
          <button class="btn ghost">Llamar</button>
        </div>
        <div class="channel">
          <div class="channel-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><path d="M22 6 12 13 2 6"></path></svg>
          </div>
          <span class="label">correo</span>
          <h4>Email formal</h4>
          <div class="num-big" style="font-size:14px; word-break:break-word;">grupocasagrandeint<wbr>@gmail.com</div>
          <p class="desc">Para órdenes de compra, cotizaciones formales y documentación.</p>
          <button class="btn ghost">Escribir</button>
        </div>
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="wrap">
      <div class="form-block">
        <div class="form-side">
          <span class="eyebrow">Formulario formal</span>
          <h3>Solicite una cotización por correo.</h3>
          <p class="lede">Para órdenes de compra estructuradas o si prefiere dejar registro escrito de su requerimiento. Respuesta en menos de 24 horas hábiles.</p>
          <div class="small">* Campos obligatorios</div>
          <div class="meta-list">
            <div><span>Dirección</span><div>Calle Neverí cruce con Carrera Uchire, C.C. Plaza Aeropuerto, Nivel 1, Local P-1-B-03, Sector UD-286 · Puerto Ordaz · Bolívar</div></div>
            <div><span>Horario</span><div>Lun-Vie 8:00 AM – 5:00 PM · Sáb 8:00 AM – 12:00 PM</div></div>
            <div><span>Razón social</span><div>Grupo Casa Grande, C.A.</div></div>
            <div><span>RIF</span><div>J-50662883-0</div></div>
            <div><span>RNC</span><div>1462945308766690240 · a nombre de Corporación Casa Grande, C.A.</div></div>
          </div>
        </div>
        <form class="cotiz" onsubmit="event.preventDefault(); alert('Demo · enviado.');">
          <div class="form-row">
            <div class="form-field">
              <label>Empresa *</label>
              <input type="text" required="" placeholder="Nombre de la empresa">
            </div>
            <div class="form-field">
              <label>RIF</label>
              <input type="text" placeholder="J-00000000-0">
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label>Nombre y apellido *</label>
              <input type="text" required="">
            </div>
            <div class="form-field">
              <label>Cargo</label>
              <input type="text">
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label>Email *</label>
              <input type="email" required="">
            </div>
            <div class="form-field">
              <label>Teléfono / WhatsApp</label>
              <input type="tel">
            </div>
          </div>
          <div class="form-field">
            <label>Tipo de requerimiento *</label>
            <div class="radio-row" id="radioGroup">
              <label class="checked"><input type="radio" name="tipo" value="ambos" checked=""><span>Ambos</span></label>
              <label><input type="radio" name="tipo" value="sum"><span>Suministros</span></label>
              <label><input type="radio" name="tipo" value="serv"><span>Servicios</span></label>
            </div>
          </div>
          <div class="form-field">
            <label>Describa su necesidad *</label>
            <textarea required="" placeholder="Indique productos, cantidades, marcas o detalles del servicio que necesita."></textarea>
          </div>
          <button class="btn lg" type="submit">Enviar solicitud →</button>
        </form>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Ubicación</span>
          <h2>Estamos en el corazón industrial de Guayana.</h2>
        </div>
      </div>
      <div class="map-block">
        <div class="ph"></div>
        <div class="map-body">
          <h3>C.C. Plaza Aeropuerto</h3>
          <div class="addr">Calle Neverí cruce con Carrera Uchire<br>Nivel 1, Local P-1-B-03 · Sector UD-286<br>Puerto Ordaz · Estado Bolívar · Venezuela</div>
          <div class="hours">Lun – Vie · 8:00 AM – 5:00 PM<br>Sáb · 8:00 AM – 12:00 PM</div>
          <div style="margin-top:8px;"><button class="btn ghost sm">Cómo llegar →</button></div>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>Una conversación que puede empezar hoy.</h3>
        <button class="btn wa lg">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          Abrir WhatsApp
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     FOOTER
     ============================================================ -->

<script>
  // Precarga del formulario según el botón de origen (?tipo=&ref=)
  const params = new URLSearchParams(window.location.search);
  const tipo = params.get('tipo');
  const ref = (params.get('ref') || '').slice(0, 160);

  if (tipo) {
    const radio = document.querySelector<HTMLInputElement>(
      `input[name="tipo"][value="${tipo}"]`
    );
    if (radio) {
      radio.checked = true;
      document
        .querySelectorAll('#radioGroup label')
        .forEach((l) => l.classList.remove('checked'));
      radio.closest('label')?.classList.add('checked');
    }
  }

  const textarea = document.querySelector<HTMLTextAreaElement>('.cotiz textarea');

  if (ref && textarea) {
    const plantillas: Record<string, string> = {
      serv: `Quiero cotizar el servicio de ${ref}. Mi requerimiento:`,
      sum: `Quiero cotizar ${ref}. Cantidad y detalles:`,
    };
    textarea.value = plantillas[tipo ?? ''] ?? `Quiero cotizar ${ref}. Detalles:`;
  }

  // Si llegó desde un botón con contexto, baja al formulario (scroll lento) y enfoca
  if ((tipo || ref) && textarea) {
    const form = textarea.closest('form') ?? textarea;
    const targetY =
      form.getBoundingClientRect().top + window.scrollY - 140; // un poco más arriba
    const startY = window.scrollY;
    const dist = targetY - startY;
    const duration = 600; // ms
    const ease = (t: number) =>
      t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    const t0 = performance.now();

    const step = (now: number) => {
      const p = Math.min((now - t0) / duration, 1);
      window.scrollTo(0, startY + dist * ease(p));
      if (p < 1) {
        requestAnimationFrame(step);
      } else {
        textarea.focus({ preventScroll: true });
        const end = textarea.value.length;
        textarea.setSelectionRange(end, end);
      }
    };
    requestAnimationFrame(step);
  }
</script>
</Layout>
