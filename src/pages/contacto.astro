---
import Layout from "../layouts/Layout.astro";
---

<Layout current="contacto" title="Contacto · Casa Grande">
<section class="view" id="view-contacto">
  <div class="page-hero">
    <div class="wrap">
      <div class="breadcrumb">Inicio <span class="sep">›</span> <span class="here">Contacto</span></div>
      <span class="eyebrow">Hablemos</span>
      <h1>Cotizaciones el mismo día.<br>Atención personalizada para su empresa.</h1>
      <p class="lede">WhatsApp es nuestro canal principal — respondemos en horas, no en días. También atendemos por llamada local y correo formal para órdenes de compra.</p>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="channels">
        <div class="channel featured">
          <div class="channel-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.9-7.01A9.81 9.81 0 0 0 12.04 2zm.01 1.67c2.2 0 4.26.86 5.82 2.42a8.21 8.21 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.24 8.24-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24zm-3.39 4.8c-.15.04-.34.18-.42.42-.08.24-.31.79-.35 1.49-.05.7.13 1.62.85 2.86 1 1.71 2.32 3.13 4.16 3.96 1.84.83 2.27.74 2.66.71.39-.03.99-.4 1.16-.79.17-.39.21-.74.16-.84-.05-.1-.18-.16-.39-.27l-1.69-.83c-.21-.11-.36-.16-.51.04l-.59.78c-.15.21-.31.24-.6.13-.29-.11-1.22-.45-2.33-1.44-.86-.77-1.44-1.71-1.59-2-.15-.29-.02-.45.12-.58.13-.13.29-.31.43-.47.14-.16.18-.27.27-.46.09-.19.05-.35-.03-.49-.08-.14-.46-1.46-.66-1.99-.16-.39-.31-.34-.42-.34h-.36c-.13 0-.34.05-.49.21z"></path></svg>
          </div>
          <span class="label" style="color:#a8a294;">canal principal</span>
          <h4>WhatsApp Business</h4>
          <div class="num-big">+58 414 8984156</div>
          <p class="desc">Cotizaciones, disponibilidad, seguimiento de pedidos y consultas técnicas. Respuesta en menos de 24 horas hábiles.</p>
          <button class="btn wa">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12c0 2 .5 3.5 1.5 5L2 22l5-1.5c1.5 1 3 1.5 5 1.5 5.5 0 10-4.5 10-10S17.5 2 12 2z"></path></svg>
            Abrir chat
          </button>
        </div>
        <div class="channel">
          <div class="channel-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <span class="label">llamada local</span>
          <h4>Teléfono fijo</h4>
          <div class="num-big">+58 286 9517336</div>
          <p class="desc">Para entes públicos y clientes que prefieren llamada. Lun-Vie · 8:00 AM – 5:00 PM.</p>
          <button class="btn ghost">Llamar</button>
        </div>
        <div class="channel">
          <div class="channel-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><path d="M22 6 12 13 2 6"></path></svg>
          </div>
          <span class="label">correo</span>
          <h4>Email formal</h4>
          <div class="num-big" style="font-size:14px; word-break:break-word;">corpcasagrande<wbr>@gmail.com</div>
          <p class="desc">Para órdenes de compra, cotizaciones formales y documentación.</p>
          <button class="btn ghost">Escribir</button>
        </div>
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="wrap">
      <div class="form-block">
        <div class="form-side">
          <span class="eyebrow">Formulario formal</span>
          <h3>Solicite una cotización por correo.</h3>
          <p class="lede">Para órdenes de compra estructuradas o si prefiere dejar registro escrito de su requerimiento. Respuesta en menos de 24 horas hábiles.</p>
          <div class="small">* Campos obligatorios</div>
          <div class="meta-list">
            <div><span>Dirección</span><div>Urb. Terrazas del Caroní, MZ 11, Casa 6D · Puerto Ordaz · Bolívar</div></div>
            <div><span>Horario</span><div>Lun-Vie 8:00 AM – 5:00 PM · Sáb 8:00 AM – 12:00 PM</div></div>
            <div><span>Razón social</span><div>Corporación Casa Grande, C.A.</div></div>
            <div><span>RIF</span><div>J-30876669-0</div></div>
            <div><span>RNC</span><div>1462945308766690240</div></div>
          </div>
        </div>
        <form class="cotiz" onsubmit="event.preventDefault(); alert('Demo · enviado.');">
          <div class="form-row">
            <div class="form-field">
              <label>Empresa *</label>
              <input type="text" required="" placeholder="Nombre de la empresa">
            </div>
            <div class="form-field">
              <label>RIF</label>
              <input type="text" placeholder="J-00000000-0">
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label>Nombre y apellido *</label>
              <input type="text" required="">
            </div>
            <div class="form-field">
              <label>Cargo</label>
              <input type="text">
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label>Email *</label>
              <input type="email" required="">
            </div>
            <div class="form-field">
              <label>Teléfono / WhatsApp</label>
              <input type="tel">
            </div>
          </div>
          <div class="form-field">
            <label>Tipo de requerimiento *</label>
            <div class="radio-row" id="radioGroup">
              <label class="checked"><input type="radio" name="tipo" value="ambos" checked=""><span>Ambos</span></label>
              <label><input type="radio" name="tipo" value="sum"><span>Suministros</span></label>
              <label><input type="radio" name="tipo" value="serv"><span>Servicios</span></label>
            </div>
          </div>
          <div class="form-field">
            <label>Describa su necesidad *</label>
            <textarea required="" placeholder="Indique productos, cantidades, marcas o detalles del servicio que necesita."></textarea>
          </div>
          <button class="btn lg" type="submit">Enviar solicitud →</button>
        </form>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Ubicación</span>
          <h2>Estamos en el corazón industrial de Guayana.</h2>
        </div>
      </div>
      <div class="map-block">
        <div class="ph"></div>
        <div class="map-body">
          <h3>Urb. Terrazas del Caroní</h3>
          <div class="addr">MZ 11, Casa 6D<br>Puerto Ordaz · Estado Bolívar · Venezuela</div>
          <div class="hours">Lun – Vie · 8:00 AM – 5:00 PM<br>Sáb · 8:00 AM – 12:00 PM</div>
          <div style="margin-top:8px;"><button class="btn ghost sm">Cómo llegar →</button></div>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>Una conversación que puede empezar hoy.</h3>
        <button class="btn wa lg">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12c0 2 .5 3.5 1.5 5L2 22l5-1.5c1.5 1 3 1.5 5 1.5 5.5 0 10-4.5 10-10S17.5 2 12 2z"></path></svg>
          Abrir WhatsApp
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     FOOTER
     ============================================================ -->
</Layout>
