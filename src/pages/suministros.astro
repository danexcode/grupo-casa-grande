---
import Layout from "../layouts/Layout.astro";
---

<Layout current="suministros" title="Suministros Industriales · Casa Grande">
<section class="view" id="view-suministros">
  <div class="page-hero">
    <div class="wrap">
      <div class="breadcrumb">Inicio <span class="sep">›</span> <span class="here">Suministros</span></div>
      <span class="eyebrow">Catálogo industrial</span>
      <h1>Suministros para la industria pesada de Guayana.</h1>
      <p class="lede">Procura especializada de equipos críticos: control de turbinas, neumática, calibración y soldadura. Sin precios públicos — cotice por WhatsApp con disponibilidad y precio del día.</p>
      <div style="display:flex; gap:12px; margin-top:32px;">
        <button class="btn wa">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          Cotizar por WhatsApp
        </button>
        <button class="btn ghost">Hablar con un asesor</button>
      </div>
    </div>
  </div>

  <section class="tight">
    <div class="wrap">
      <div class="sumi-grid">
        <article class="sumi-card" data-go="categoria">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 01</span>
            <h4>Automatización y Control Industrial</h4>
            <p class="items">Controladores de turbinas · gobernadores de velocidad · sensores e interruptores.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 02</span>
            <h4>Neumática, Válvulas y Fluidos</h4>
            <p class="items">Actuadores lineales · bombas neumáticas · compresores de aire.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 03</span>
            <h4>Herramientas Especializadas y Calibración</h4>
            <p class="items">Torque y medición · equipos de oxicorte.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 04</span>
            <h4>Iluminación Industrial de Alta Potencia</h4>
            <p class="items">Reflectores LED · luminarias Highbay.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 05</span>
            <h4>Mantenimiento Mecánico y Polímeros</h4>
            <p class="items">Resinas epóxicas · absorbente de hidrocarburos.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 06</span>
            <h4>Fijación Estructural y Mecánica (Tornillería)</h4>
            <p class="items">Tornillería estructural Grado 5/8, inox y galvanizada · anclajes de alta tensión · fijaciones para bridas y tuberías de alta presión.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 07</span>
            <h4>Aleaciones y Consumibles de Soldadura</h4>
            <p class="items">Electrodos revestidos (aleaciones A/I) · TIG/MIG/Arco sumergido · oxicorte y preparación de superficies.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card cta" data-go="contacto">
          <div class="cta-mark"><span>+</span></div>
          <div class="sumi-card-body">
            <span class="num">Cotización</span>
            <h4>¿No ve su categoría?</h4>
            <p class="items">Díganos marca y referencia. Cotizamos con disponibilidad y precio del día.</p>
          </div>
          <div class="sumi-card-foot">Cotizar por WhatsApp</div>
        </article>
      </div>
    </div>
  </section>

  <section class="alt tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Productos destacados</span>
          <h2>Equipos críticos que manejamos.</h2>
        </div>
        <div class="lede">Marca y modelo. El resto del catálogo, bajo pedido por WhatsApp.</div>
      </div>
      <div class="sumi-grid">
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Woodward</span>
            <h4>Control Digital Peak 150</h4>
            <p class="items">Controlador digital para turbinas de vapor.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Trisen</span>
            <h4>Gobernador 310</h4>
            <p class="items">Gobernador electrónico de velocidad.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Schmersal</span>
            <h4>Sensores IP67</h4>
            <p class="items">Interruptores y sensores de seguridad.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Valtek</span>
            <h4>Actuador 25 SQ.IN</h4>
            <p class="items">Actuador lineal para válvulas de control.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">ARO</span>
            <h4>Bomba de achique</h4>
            <p class="items">Bomba sumergible neumática.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Dewalt</span>
            <h4>Compresor 3.5 HP</h4>
            <p class="items">Reciprocante de aire, 60 galones.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Stanley Proto</span>
            <h4>Llave dinamométrica</h4>
            <p class="items">Encastre 3/4" · 120–600 ft-lb.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">Uniweld · Victor</span>
            <h4>Medalist 350</h4>
            <p class="items">Equipo de oxicorte.</p>
          </div>
          <div class="sumi-card-foot">Cotizar</div>
        </article>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Marcas</span>
          <h2>Las marcas detrás de nuestros equipos.</h2>
        </div>
        <div class="lede">Si no ve la marca o referencia que busca, escríbanos por WhatsApp — gestionamos procura bajo pedido.</div>
      </div>
      <div class="brands">
        <div class="ph" data-brand="Woodward"></div>
        <div class="ph" data-brand="Trisen"></div>
        <div class="ph" data-brand="Schmersal"></div>
        <div class="ph" data-brand="Valtek"></div>
        <div class="ph" data-brand="ARO"></div>
        <div class="ph" data-brand="Dewalt"></div>
        <div class="ph" data-brand="Stanley"></div>
        <div class="ph" data-brand="Proto"></div>
        <div class="ph" data-brand="Uniweld"></div>
        <div class="ph" data-brand="Victor Medalist"></div>
        <div class="ph" data-brand="Bilight"></div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>¿No encuentra lo que busca?<br>Gestionamos procura bajo pedido.</h3>
        <button class="btn wa lg">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          Pregúntenos
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     CATEGORÍA · ELÉCTRICO — V1
     ============================================================ -->
</Layout>
