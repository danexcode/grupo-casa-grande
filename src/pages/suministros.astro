---
import Layout from "../layouts/Layout.astro";
---

<Layout current="suministros" title="Suministros Industriales · Casa Grande">
<section class="view" id="view-suministros">
  <div class="page-hero">
    <div class="wrap">
      <div class="breadcrumb">Inicio <span class="sep">›</span> <span class="here">Suministros</span></div>
      <span class="eyebrow">Catálogo industrial</span>
      <h1>Suministros para la industria pesada de Guayana.</h1>
      <p class="lede">Más de 50 categorías y 20 marcas líderes. Sin precios públicos — cotice por WhatsApp con disponibilidad y precio del día.</p>
      <div style="display:flex; gap:12px; margin-top:32px;">
        <button class="btn wa">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          Cotizar por WhatsApp
        </button>
        <button class="btn ghost">Hablar con un asesor</button>
      </div>
    </div>
  </div>

  <section class="tight">
    <div class="wrap">
      <div class="filter-bar">
        <span class="lbl">Filtrar</span>
        <div class="chips">
          <button class="chip active">Todas</button>
          <button class="chip">Eléctrico</button>
          <button class="chip">Refrigeración</button>
          <button class="chip">Ferretería</button>
          <button class="chip">Soldadura</button>
          <button class="chip">Iluminación</button>
          <button class="chip">Construcción</button>
          <button class="chip">Seguridad</button>
          <button class="chip">Herramientas</button>
        </div>
      </div>

      <div class="sumi-grid">
        <article class="sumi-card" data-go="categoria">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 01</span>
            <h4>Eléctrico</h4>
            <p class="items">Cables TF · THW · THHW · TTU. Relés y contactores. Iluminación industrial.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 02</span>
            <h4>Refrigeración</h4>
            <p class="items">Compresores · gases · capacitores · válvulas de expansión.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 03</span>
            <h4>Ferretería</h4>
            <p class="items">Tornillería galvanizada y de acero inoxidable. Hierro · rodamientos.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 04</span>
            <h4>Soldadura</h4>
            <p class="items">Picos de soldar · electrodos · cable y accesorios de seguridad.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 05</span>
            <h4>Iluminación</h4>
            <p class="items">Paneles LED · bombillos · lámparas · reflectores industriales.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 06</span>
            <h4>Construcción</h4>
            <p class="items">Cabillas · láminas · perfiles IPN · madera de pino · PVC.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 07</span>
            <h4>Seguridad industrial</h4>
            <p class="items">Equipos de protección personal · señalización · 3M, Honeywell.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
        <article class="sumi-card">
          <div class="ph"></div>
          <div class="sumi-card-body">
            <span class="num">cat · 08</span>
            <h4>Herramientas</h4>
            <p class="items">Stanley · Proto · Bellota · herramienta manual y eléctrica.</p>
          </div>
          <div class="sumi-card-foot">Ver categoría</div>
        </article>
      </div>
    </div>
  </section>

  <section class="alt tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Marcas aliadas</span>
          <h2>+20 marcas líderes en suministros industriales.</h2>
        </div>
        <div class="lede">Si no ve la marca o referencia que busca, escríbanos por WhatsApp. Manejamos más de 1000 referencias adicionales.</div>
      </div>
      <div class="brands">
        <div class="ph" data-brand="Siemens"></div>
        <div class="ph" data-brand="Schneider"></div>
        <div class="ph" data-brand="ABB"></div>
        <div class="ph" data-brand="Telemecanique"></div>
        <div class="ph" data-brand="3M"></div>
        <div class="ph" data-brand="SKF"></div>
        <div class="ph" data-brand="Stanley"></div>
        <div class="ph" data-brand="Proto"></div>
        <div class="ph" data-brand="Honeywell"></div>
        <div class="ph" data-brand="Danfoss"></div>
        <div class="ph" data-brand="Emerson"></div>
        <div class="ph" data-brand="Bellota"></div>
        <div class="ph" data-brand="GE"></div>
        <div class="ph" data-brand="Mabe"></div>
        <div class="ph" data-brand="Everwell"></div>
        <div class="ph" data-brand="Uniteca"></div>
        <div class="ph" data-brand="HoffmanArc"></div>
        <div class="ph" data-brand="Thermo Scientific"></div>
        <div class="ph" data-brand="Exceline"></div>
        <div class="ph" data-brand="Appli Parts"></div>
        <div class="ph" data-brand="Weldtech"></div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>¿No encuentra lo que busca?<br>Manejamos +1000 referencias.</h3>
        <button class="btn wa lg">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          Pregúntenos
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
