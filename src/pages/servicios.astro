---
import Layout from "../layouts/Layout.astro";
---

<Layout current="servicios" title="Servicios Industriales · Casa Grande">
<section class="view" id="view-servicios">
  <div class="page-hero">
    <div class="wrap">
      <div class="breadcrumb">Inicio <span class="sep">›</span> <span class="here">Servicios</span></div>
      <span class="eyebrow">Servicios industriales</span>
      <h1>Cuatro especialidades. Veinte años haciéndolas.</h1>
      <p class="lede">Mantenimiento y obra para CORPOELEC, CVG, PDVSA y empresas privadas de Guayana. Cada servicio respaldado por contratos del Registro Nacional de Contratistas.</p>
    </div>
  </div>

  <div class="wrap">

    <div class="service">
      <div class="service-media"><div class="ph"></div></div>
      <div>
        <div class="num">SERVICIO 01</div>
        <h3>Chillers, HVAC y refrigeración industrial.</h3>
        <p>Mantenimiento preventivo y correctivo de chillers, sistemas centrales de aire acondicionado y unidades manejadoras de aire. Atendemos sistemas industriales y comerciales de cualquier capacidad.</p>
        <div class="clients">
          <div class="lbl">Experiencia comprobable</div>
          <ul>
            <li>CVG · Sistema HVAC Edificio CVG II</li>
            <li>CVG · Reparación chiller y UMAS Hospital Uyapar</li>
            <li>Centro de Rehabilitación Dr. Carlos Fragachan</li>
          </ul>
        </div>
        <button class="btn rust">Solicitar cotización</button>
      </div>
    </div>

    <div class="service reverse">
      <div class="service-media"><div class="ph"></div></div>
      <div>
        <div class="num">SERVICIO 02</div>
        <h3>Mantenimiento de corredores eléctricos.</h3>
        <p>Especialistas en desmalezamiento de líneas de transmisión a 115 kV, 400 kV y 765 kV. Mantenimiento de áreas verdes y vías de acceso del sistema de transmisión troncal y regional.</p>
        <div class="clients">
          <div class="lbl">Experiencia comprobable</div>
          <ul>
            <li>CORPOELEC · Sectores A y B, líneas 765 kV (5 contratos)</li>
            <li>CORPOELEC · Sector 4, líneas 400 kV</li>
            <li>EDELCA · Sistema de Transmisión Oriente</li>
          </ul>
        </div>
        <button class="btn rust">Solicitar cotización</button>
      </div>
    </div>

    <div class="service">
      <div class="service-media"><div class="ph"></div></div>
      <div>
        <div class="num">SERVICIO 03</div>
        <h3>Instalaciones eléctricas BT / MT / AT.</h3>
        <p>Proyectos eléctricos industriales: diseño, instalación y mantenimiento en baja, media y alta tensión. Tableros, transformadores, líneas y sistemas de protección.</p>
        <div class="clients">
          <div class="lbl">Capacidad técnica</div>
          <ul>
            <li>Personal calificado en MT y AT</li>
            <li>Equipos certificados para trabajo en altura</li>
          </ul>
        </div>
        <button class="btn rust">Solicitar cotización</button>
      </div>
    </div>

    <div class="service reverse">
      <div class="service-media"><div class="ph"></div></div>
      <div>
        <div class="num">SERVICIO 04</div>
        <h3>Refrescamiento y remodelación de espacios.</h3>
        <p>Renovación y acondicionamiento de oficinas, fachadas, áreas administrativas y de atención al público. Acabados, pintura, mobiliario industrial liviano.</p>
        <button class="btn rust">Solicitar cotización</button>
      </div>
    </div>

  </div>

  <section class="alt">
    <div class="wrap">
      <div class="rnc-card" style="background:var(--paper); color:var(--ink); border:1px solid var(--line);">
        <div class="rnc-seal">
          <span class="x">+30</span>
          <span class="y">OBRAS · 100%</span>
        </div>
        <div>
          <h3 style="font-size:30px;">Contratista del Estado · RNC vigente</h3>
          <p class="lede" style="color:var(--ink-3);">Habilitados para contratar con la Administración Pública Nacional, Estadal y Municipal. Treinta contratos ejecutados al 100% — sin retrasos, sin reclamos.</p>
        </div>
        <button class="btn ghost" data-go="experiencia">Ver historial</button>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>¿Listo para su próximo proyecto?</h3>
        <button class="btn wa lg">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
          Hablemos por WhatsApp
        </button>
      </div>
    </div>
  </div>
</section>

