---
import Layout from "../layouts/Layout.astro";
---

<Layout current="home">
<section class="view active" id="view-home">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="top-meta">
          <span class="label paper">desde 2001 · Puerto Ordaz</span>
          <span class="label paper">contratista del estado</span>
        </div>
        <div>
          <h1>+30 obras<br>al <span class="accent">100%</span><br>para CORPOELEC,<br>CVG y PDVSA.</h1>
          <p class="sub">Suministros industriales y servicios de mantenimiento eléctrico, refrigeración y obra civil para la industria pesada de Guayana.</p>
          <div class="hero-ctas">
            <button class="btn wa lg">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.9-7.01A9.81 9.81 0 0 0 12.04 2zm.01 1.67c2.2 0 4.26.86 5.82 2.42a8.21 8.21 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.24 8.24-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24z"></path></svg>
              Cotizar por WhatsApp
            </button>
            <button class="btn ghost lg" data-go="experiencia" style="color:var(--paper);border-color:var(--paper);">Ver historial de obras</button>
          </div>
        </div>
        <div class="hero-rnc">
          <div class="seal"></div>
          <div class="info">
            <div class="ttl">Registro Nacional de Contratistas · vigente</div>
            <div class="num">Nº 1462945308766690240 · 30·06·2025 – 30·06·2026</div>
          </div>
        </div>
      </div>
      <div class="hero-side">
        <div class="ph"></div>
        <div class="hero-stats">
          <div class="hero-stat"><div class="num"><span class="pre">+</span>20</div><div class="lbl">años de operación</div></div>
          <div class="hero-stat"><div class="num"><span class="pre">+</span>30</div><div class="lbl">obras ejecutadas</div></div>
          <div class="hero-stat"><div class="num">100%</div><div class="lbl">cumplimiento</div></div>
          <div class="hero-stat"><div class="num"><span class="pre">+</span>1000</div><div class="lbl">ventas</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- TRUST -->
  <div class="trust">
    <div class="trust-inner">
      <div class="lead">Confían en nosotros las empresas más grandes de Guayana</div>
      <div class="trust-logos">
        <div class="ph"></div><div class="ph"></div><div class="ph"></div>
        <div class="ph"></div><div class="ph"></div><div class="ph"></div>
      </div>
    </div>
  </div>

  <!-- TIMELINE -->
  <section>
    <div class="wrap">
      <div class="section-head center">
        <span class="eyebrow">Trayectoria</span>
        <h2 style="text-align:center;">Dos décadas creciendo con la industria venezolana.</h2>
      </div>
      <div class="timeline">
        <div class="timeline-track"></div>
        <div class="timeline-nodes">
          <div class="tl-node"><div class="dot"></div><div class="year">2001</div><div class="desc">Fundación · Puerto Ordaz</div></div>
          <div class="tl-node active"><div class="dot"></div><div class="year">2004</div><div class="desc">Primer contrato CVG</div></div>
          <div class="tl-node active"><div class="dot"></div><div class="year">2008</div><div class="desc">CORPOELEC · corredores 400 kV</div></div>
          <div class="tl-node active"><div class="dot"></div><div class="year">2011</div><div class="desc">PDVSA · entrada Boquerón</div></div>
          <div class="tl-node active"><div class="dot"></div><div class="year">2016</div><div class="desc">Líneas 765 kV · lote A y B</div></div>
          <div class="tl-node"><div class="dot"></div><div class="year">2025</div><div class="desc">Grupo Casa Grande</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- DOUBLE PILLAR -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Dos pilares</span>
          <h2>Suministros y servicios bajo un mismo techo.</h2>
        </div>
        <div class="lede">El catálogo y la mano de obra que la industria pesada necesita — desde una atornilladora hasta un sistema HVAC completo.</div>
      </div>
      <div class="pillars">
        <div class="pillar" data-go="suministros">
          <div class="ph"></div>
          <div class="pillar-body">
            <span class="label accent">/ Suministros industriales</span>
            <h3>Catálogo de +50 categorías y +20 marcas.</h3>
            <p class="desc">Eléctrico, refrigeración, soldadura, ferretería pesada, iluminación, EPP. Trabajamos con Siemens, Schneider, ABB, 3M, SKF y más.</p>
            <div class="meta">
              <div><div class="n">+50</div><div class="l">categorías</div></div>
              <div><div class="n">+1000</div><div class="l">referencias</div></div>
              <div><div class="n">+20</div><div class="l">marcas</div></div>
            </div>
            <div class="arrow">Ver catálogo</div>
          </div>
        </div>
        <div class="pillar" data-go="servicios">
          <div class="ph"></div>
          <div class="pillar-body">
            <span class="label accent">/ Servicios técnicos</span>
            <h3>Mantenimiento y obra de campo.</h3>
            <p class="desc">Chillers y HVAC, mantenimiento de corredores eléctricos 115/400/765 kV, instalaciones eléctricas y remodelación de espacios.</p>
            <div class="meta">
              <div><div class="n">4</div><div class="l">líneas activas</div></div>
              <div><div class="n">+30</div><div class="l">obras</div></div>
              <div><div class="n">RNC</div><div class="l">vigente</div></div>
            </div>
            <div class="arrow">Ver servicios</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASES -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Casos seleccionados</span>
          <h2>Lo que hemos construido y mantenido.</h2>
        </div>
        <div class="lede">Una muestra de los contratos del Registro Nacional de Contratistas. <a style="color:var(--rust);font-weight:600;border-bottom:1px solid var(--rust);cursor:pointer;" data-go="experiencia">Ver los 17 contratos →</a></div>
      </div>
      <div class="cases">
        <article class="case">
          <div class="ph"></div>
          <div class="case-body">
            <span class="client">CORPOELEC · 2014–2017</span>
            <h4>Mtto. de corredores 765 kV · Sectores A y B</h4>
            <p class="summary">Mantenimiento de corredores de servicio y vías de acceso en líneas de transmisión a 765 kV. Cinco contratos consecutivos.</p>
            <div class="case-foot"><span class="badge">100%</span><span>5 contratos · 3 años</span></div>
          </div>
        </article>
        <article class="case">
          <div class="ph"></div>
          <div class="case-body">
            <span class="client">CVG · 2004–2005</span>
            <h4>Sistema HVAC · Hospital Uyapar</h4>
            <p class="summary">Reparación de sistema CHILLER y UMAS del aire acondicionado del hospital. Suministro, transporte e instalación.</p>
            <div class="case-foot"><span class="badge">100%</span><span>Contrato 32004-0673</span></div>
          </div>
        </article>
        <article class="case">
          <div class="ph"></div>
          <div class="case-body">
            <span class="client">PDVSA · 2011–2012</span>
            <h4>Construcción entrada Boquerón</h4>
            <p class="summary">Construcción de obra civil de acceso a planta. Contrato A-60-11-030.</p>
            <div class="case-foot"><span class="badge">100%</span><span>8 meses</span></div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- CATEGORIES FEATURED -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Suministros · categorías</span>
          <h2>Lo que la industria nos pide.</h2>
        </div>
        <div class="lede">Más de 50 categorías. Cotice por WhatsApp con la disponibilidad real del día.</div>
      </div>
      <div class="cat-grid">
        <div class="cat-card"><span class="num">01</span><h4>Eléctrico</h4><div class="items">Cables · relés · contactores</div></div>
        <div class="cat-card"><span class="num">02</span><h4>Refrigeración</h4><div class="items">Compresores · gases · partes</div></div>
        <div class="cat-card"><span class="num">03</span><h4>Ferretería</h4><div class="items">Tornillo · hierro · rodamientos</div></div>
        <div class="cat-card"><span class="num">04</span><h4>Soldadura</h4><div class="items">Electrodos · picos · cable</div></div>
        <div class="cat-card"><span class="num">05</span><h4>Iluminación</h4><div class="items">LED · reflectores · lámparas</div></div>
        <div class="cat-card"><span class="num">06</span><h4>Construcción</h4><div class="items">Cabilla · madera · PVC</div></div>
        <div class="cat-card"><span class="num">07</span><h4>Seguridad</h4><div class="items">EPP · señalización</div></div>
        <div class="cat-card"><span class="num">08</span><h4>Herramientas</h4><div class="items">Proto · Stanley · Bellota</div></div>
      </div>
      <div style="margin-top:32px; display:flex; justify-content:center;">
        <button class="btn ghost" data-go="suministros">Ver catálogo completo</button>
      </div>
    </div>
  </section>

  <!-- BRANDS -->
  <section class="tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Marcas aliadas</span>
          <h2>Los nombres que la industria pide por su número de parte.</h2>
        </div>
      </div>
      <div class="brands">
        <div class="ph" data-brand="Siemens"></div>
        <div class="ph" data-brand="Schneider"></div>
        <div class="ph" data-brand="ABB"></div>
        <div class="ph" data-brand="3M"></div>
        <div class="ph" data-brand="SKF"></div>
        <div class="ph" data-brand="Stanley"></div>
        <div class="ph" data-brand="Proto"></div>
        <div class="ph" data-brand="Honeywell"></div>
        <div class="ph" data-brand="Danfoss"></div>
        <div class="ph" data-brand="Emerson"></div>
        <div class="ph" data-brand="Bellota"></div>
        <div class="ph" data-brand="GE"></div>
        <div class="ph" data-brand="Mabe"></div>
        <div class="ph" data-brand="+ 8"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>¿Necesita una cotización?<br>Le respondemos hoy mismo.</h3>
        <div style="display:flex; gap:12px;">
          <button class="btn wa lg">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.9-7.01A9.81 9.81 0 0 0 12.04 2z"></path></svg>
            Abrir WhatsApp
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     NOSOTROS — V1 Timeline
     ============================================================ -->
</Layout>
