---
import Layout from "../layouts/Layout.astro";
---

<Layout current="home">
<section class="view active" id="view-home">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="top-meta">
          <span class="label paper">desde 2001 · Puerto Ordaz</span>
          <span class="label paper">contratista del estado</span>
        </div>
        <div>
          <h1>Suministros y Servicios Industriales<br>para la Industria de <span class="accent">Guayana</span></h1>
          <p class="sub">Grupo Casa Grande continúa la trayectoria de Corporación Casa Grande, C.A. — mismo equipo, 25 años de obras cumplidas.</p>
          <div class="hero-ctas">
            <button class="btn wa lg">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
              Cotizar por WhatsApp
            </button>
            <button class="btn ghost lg" data-go="experiencia" style="color:var(--paper);border-color:var(--paper);">Ver historial de obras</button>
          </div>
        </div>
        <div class="hero-rnc">
          <div class="seal"></div>
          <div class="info">
            <div class="ttl">Registro Nacional de Contratistas · vigente</div>
            <div class="num">Nº 1462945308766690240 · 30·06·2025 – 30·06·2026</div>
            <div class="num">A nombre de Corporación Casa Grande, C.A.</div>
          </div>
        </div>
      </div>
      <div class="hero-side">
        <img class="hero-img" src="/images/pages/planta-ferrominera-1.jpg" alt="Planta de Ferrominera, industria pesada de Guayana" />
        <div class="hero-stats">
          <div class="hero-stat"><div class="num">25</div><div class="lbl">años de operación</div></div>
          <div class="hero-stat"><div class="num"><span class="pre">+</span>30</div><div class="lbl">obras ejecutadas</div></div>
          <div class="hero-stat"><div class="num">100%</div><div class="lbl">cumplimiento</div></div>
          <div class="hero-stat"><div class="num"><span class="pre">+</span>1000</div><div class="lbl">ventas</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- TRUST -->
  <div class="trust">
    <div class="trust-inner">
      <div class="lead">Las empresas más grandes de Guayana confían en nosotros</div>
      <div class="trust-logos">
        <div class="logo-cell"><img src="/images/clients/corpoelec-logo.png" alt="CORPOELEC" /></div>
        <div class="logo-cell"><img src="/images/clients/cvg.webp" alt="CVG" /></div>
        <div class="logo-cell"><img src="/images/clients/pdvsa.webp" alt="PDVSA" /></div>
        <div class="logo-cell"><img src="/images/clients/edelca-logo.webp" alt="EDELCA" /></div>
      </div>
    </div>
  </div>

  <!-- DOUBLE PILLAR -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Qué hacemos</span>
          <h2>Suministros y servicios bajo un mismo techo.</h2>
        </div>
        <div class="lede">El catálogo y la mano de obra que la industria pesada necesita — desde una atornilladora hasta un sistema HVAC completo.</div>
      </div>
      <div class="pillars">
        <div class="pillar" data-go="suministros">
          <img class="pillar-img" src="/images/pages/suministros-industriales-1.jpg" alt="Suministros industriales" />
          <div class="pillar-body">
            <span class="label accent">/ Suministros industriales</span>
            <h3>Repuestos, equipos y consumibles para la industria.</h3>
            <p class="desc">Automatización y control, neumática y válvulas, herramientas y calibración, iluminación industrial, tornillería estructural y consumibles de soldadura. Trabajamos con Woodward, Schmersal, Valtek, Stanley Proto, Dewalt y más.</p>
            <div class="meta">
              <div><div class="n">7</div><div class="l">categorías</div></div>
              <div><div class="n">+15</div><div class="l">subcategorías</div></div>
              <div><div class="n">+10</div><div class="l">marcas</div></div>
            </div>
            <div class="arrow">Ver catálogo</div>
          </div>
        </div>
        <div class="pillar" data-go="servicios">
          <img class="pillar-img" src="/images/pages/hvac-chiller-1.jpeg" alt="Servicios técnicos y mantenimiento industrial" />
          <div class="pillar-body">
            <span class="label accent">/ Servicios técnicos</span>
            <h3>Servicios técnicos y mantenimiento industrial.</h3>
            <p class="desc">Climatización y refrigeración industrial (HVAC), proyectos eléctricos e iluminación, adecuación de espacios corporativos y control de vegetación en corredores eléctricos.</p>
            <div class="meta">
              <div><div class="n">4</div><div class="l">líneas activas</div></div>
              <div><div class="n">+30</div><div class="l">obras</div></div>
              <div><div class="n">RNC</div><div class="l">vigente</div></div>
            </div>
            <div class="arrow">Ver servicios</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES FEATURED -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Suministros · categorías</span>
          <h2>Lo que la industria nos pide.</h2>
        </div>
        <div class="lede">7 categorías especializadas. Cotice por WhatsApp con la disponibilidad real del día.</div>
      </div>
      <div class="cat-grid">
        <div class="cat-card" data-href="/suministros/automatizacion-y-control"><span class="num">01</span><h4>Automatización y Control</h4><div class="items">Controladores · gobernadores · sensores</div></div>
        <div class="cat-card"><span class="num">02</span><h4>Neumática, Válvulas y Fluidos</h4><div class="items">Actuadores · bombas · compresores</div></div>
        <div class="cat-card"><span class="num">03</span><h4>Herramientas y Calibración</h4><div class="items">Torque · medición · oxicorte</div></div>
        <div class="cat-card"><span class="num">04</span><h4>Iluminación Industrial</h4><div class="items">Reflectores LED · luminarias highbay</div></div>
        <div class="cat-card"><span class="num">05</span><h4>Mant. Mecánico y Polímeros</h4><div class="items">Resinas epóxicas · absorbentes</div></div>
        <div class="cat-card"><span class="num">06</span><h4>Tornillería Estructural</h4><div class="items">Grado 5 y 8 · anclajes · fijaciones</div></div>
        <div class="cat-card"><span class="num">07</span><h4>Soldadura Industrial</h4><div class="items">Electrodos · TIG · MIG · arco sumergido</div></div>
        <div class="cat-card cat-cta" data-go="suministros"><h4>Ver catálogo completo</h4><div class="items">Las 7 categorías y sus subcategorías →</div></div>
      </div>
    </div>
  </section>

  <!-- CASES -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Proyectos destacados</span>
          <h2>Lo que hemos construido y mantenido.</h2>
        </div>
        <div class="lede">Una muestra de los contratos del Registro Nacional de Contratistas. <a style="color:var(--rust);font-weight:600;border-bottom:1px solid var(--rust);cursor:pointer;" data-go="experiencia">Ver los 17 contratos →</a></div>
      </div>
      <div class="cases">
        <article class="case">
          <img class="case-img" src="/images/pages/casa-grande-12.png" alt="Mtto. de corredores 765 kV · Sectores A y B" />
          <div class="case-body">
            <span class="client">CORPOELEC · 2014–2017</span>
            <h4>Mtto. de corredores 765 kV · Sectores A y B</h4>
            <p class="summary">Mantenimiento de corredores de servicio y vías de acceso en líneas de transmisión a 765 kV. Cinco contratos consecutivos.</p>
            <div class="case-foot"><span class="badge">100%</span><span>5 contratos · 3 años</span></div>
          </div>
        </article>
        <article class="case">
          <img class="case-img" src="/images/pages/hvac-chillers-3.webp" alt="Sistema HVAC · Hospital Uyapar" />
          <div class="case-body">
            <span class="client">CVG · 2004–2005</span>
            <h4>Sistema HVAC · Hospital Uyapar</h4>
            <p class="summary">Reparación de sistema CHILLER y UMAS del aire acondicionado del hospital. Suministro, transporte e instalación.</p>
            <div class="case-foot"><span class="badge">100%</span><span>Contrato 32004-0673</span></div>
          </div>
        </article>
        <article class="case">
          <img class="case-img" src="/images/pages/pdvsa-boqueron.jpg" alt="Construcción entrada Boquerón" />
          <div class="case-body">
            <span class="client">PDVSA · 2011–2012</span>
            <h4>Construcción entrada Boquerón</h4>
            <p class="summary">Construcción de obra civil de acceso a planta. Contrato A-60-11-030.</p>
            <div class="case-foot"><span class="badge">100%</span><span>8 meses</span></div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- BRANDS -->
  <section class="tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Marcas aliadas</span>
          <h2>Los nombres que la industria pide por su número de parte.</h2>
        </div>
      </div>
      <div class="brands">
        <div class="ph" data-brand="Woodward"></div>
        <div class="ph" data-brand="Trisen"></div>
        <div class="ph" data-brand="Schmersal"></div>
        <div class="ph" data-brand="Valtek"></div>
        <div class="ph" data-brand="ARO"></div>
        <div class="ph" data-brand="Dewalt"></div>
        <div class="ph" data-brand="Stanley"></div>
        <div class="ph" data-brand="Proto"></div>
        <div class="ph" data-brand="Uniweld"></div>
        <div class="ph" data-brand="Victor"></div>
        <div class="ph" data-brand="Bilight"></div>
        <div class="ph" data-brand="+ más"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>¿Necesita una cotización?<br>Le respondemos hoy mismo.</h3>
        <div style="display:flex; gap:12px;">
          <button class="btn wa lg">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426"></path></svg>
            Abrir WhatsApp
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     NOSOTROS — V1 Timeline
     ============================================================ -->
</Layout>
