---
import Layout from "../../layouts/Layout.astro";
import { categorias } from "../../data/categorias";

export function getStaticPaths() {
  return categorias.map((cat) => ({ params: { categoria: cat.slug }, props: { cat } }));
}

const { cat } = Astro.props;
const waPath =
  "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.943c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.582 0 11.94-5.359 11.944-11.945a11.864 11.864 0 0 0-3.495-8.426";
---

<Layout current="suministros" title={`${cat.titulo} · Casa Grande`}>
<section class="view" id="view-categoria">
  <div class="wrap" style="padding-top:32px;">
    <div class="breadcrumb">Inicio <span class="sep">›</span> <a data-go="suministros" style="cursor:pointer;border-bottom:1px solid var(--line-2);">Suministros</a> <span class="sep">›</span> <span class="here">{cat.titulo}</span></div>
  </div>

  <div class="cat-hero">
    <div class="cat-hero-left">
      <span class="eyebrow">Categoría {cat.num}</span>
      <h1>{cat.titulo}</h1>
      <p class="lede">{cat.lede}</p>
      <div style="display:flex; gap:12px;">
        <button class="btn wa" data-wa-msg={cat.waMsg}>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d={waPath}></path></svg>
          Cotizar esta categoría
        </button>
      </div>
    </div>
    <div class="cat-hero-right"><div class="ph"></div></div>
  </div>

  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Subcategorías</span>
          <h2>{cat.subcategorias.length} líneas de producto.</h2>
        </div>
      </div>
      <div class="subcat-grid">
        {cat.subcategorias.map((s) => (
          <div class="subcat-card">
            <div class="ph"></div>
            <h4>{s.titulo}</h4>
            <div class="items">{s.items}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Productos destacados</span>
          <h2>Algunas de las referencias que manejamos.</h2>
        </div>
        <div class="lede">Una muestra. Si su referencia no está, consúltenos — manejamos cientos más.</div>
      </div>
      <div class="products">
        {cat.productos.map((p) => (
          <article class="product">
            <div class="ph"></div>
            <div class="product-body">
              <span class="brand">{p.brand}</span>
              <h4>{p.nombre}</h4>
              <p class="spec">{p.spec}</p>
            </div>
            <div class="product-cta">Cotizar por WhatsApp</div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">Marcas disponibles</span>
          <h2>En esta categoría trabajamos con:</h2>
        </div>
      </div>
      <div class="brands" style={`grid-template-columns:repeat(${Math.min(cat.marcas.length, 6)},1fr);`}>
        {cat.marcas.map((m) => (
          <div class="ph" data-brand={m}></div>
        ))}
      </div>
    </div>
  </section>

  <section class="alt tight">
    <div class="wrap">
      <div class="section-head" style="margin-bottom:24px;">
        <div>
          <span class="eyebrow">También te puede interesar</span>
          <h2 style="font-size:32px;">Más categorías de suministros.</h2>
        </div>
      </div>
      <div style="display:flex; gap:16px; flex-wrap:wrap;">
        <button class="chip" style="padding:12px 22px; font-size:14px;" data-href="/suministros">→ Ver todo el catálogo</button>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="wrap">
      <div class="cta-band-inner">
        <h3>¿Tiene una referencia específica en mente?</h3>
        <button class="btn wa lg" data-wa-msg={cat.waMsg}>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d={waPath}></path></svg>
          Consultar disponibilidad
        </button>
      </div>
    </div>
  </div>
</section>
</Layout>
